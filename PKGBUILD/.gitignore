# Ignore all files by default
*

# Allow first-level directories (to traverse them)
!*/

# Track PKGBUILD, README.md, and checksums.txt in the first-level directories
!*/PKGBUILD
!*/README.md
!*/checksums.txt

# Allow the root .gitignore file
!.gitignore

# Active exceptions for Antigravity sub-projects
!*/Agent-Orchestrator/
!*/Agent-Orchestrator/PKGBUILD
!*/Agent-Orchestrator/antigravity-orchestrator.install
!*/Agent-Orchestrator/agyagent.svg
!*/Agent-Orchestrator/agyagent.png
!*/Agent-Orchestrator/README.md
!*/Agent-Orchestrator/checksums.txt

!*/CLI/
!*/CLI/PKGBUILD
!*/CLI/antigravity-cli.install
!*/CLI/agy.svg
!*/CLI/agyb.svg
!*/CLI/agy.png
!*/CLI/README.md
!*/CLI/checksums.txt

!*/IDE/
!*/IDE/PKGBUILD
!*/IDE/antigravity-ide.install
!*/IDE/code.svg
!*/IDE/code.png
!*/IDE/README.md
!*/IDE/checksums.txt

!*/xone-dkms-git-custom/checksums.txt

# Maintainer: CheckTopLeft - Dont@reach.me
# Remnants: ~/.gemini/antigravity-ide (run post_remove or remove manually).

pkgname=antigravity-ide
pkgver=2.1.1
_build=6123990880747520
pkgrel=1
pkgdesc="Google Antigravity IDE agentic development platform"
arch=('x86_64')
url="https://antigravity.google/"
license=('custom:Proprietary')
depends=('alsa-lib' 'gtk3' 'nss' 'nspr' 'libxss' 'libxtst')
options=('!strip' '!debug')
install=antigravity-ide.install
source=("Antigravity_IDE.tar.gz::https://edgedl.me.gvt1.com/edgedl/release2/j0qc3/antigravity/stable/${pkgver}-${_build}/linux-x64/Antigravity%20IDE.tar.gz"
        "code.svg::https://raw.githubusercontent.com/Groupiely/Zbeul/main/PKGBUILD/Antigravity/IDE/code.svg")
sha512sums=('SKIP'
            'f821b24e72770e582d190d00c0f1ac63ef59a9e664eae8eb74da8a8f3272b5bbf9de96500d4802eca74e7912708edf28608ac498bce9b3d0e01173e7b8d831a7')

package() {
  install -d "${pkgdir}/${HOME}/.local/share/Antigravity IDE"
  local ext_dir=$(find "${srcdir}" -maxdepth 1 -type d -name "Antigravity IDE*" | head -n 1)
  cp -a "${ext_dir}/"* "${pkgdir}/${HOME}/.local/share/Antigravity IDE/"

  install -d "${pkgdir}/${HOME}/.local/bin"
  ln -sf "../share/Antigravity IDE/bin/antigravity-ide" "${pkgdir}/${HOME}/.local/bin/antigravity-ide"

  local icon_dir=""
  if [ -n "${XCURSOR_PATH}" ]; then
    IFS=':' read -ra ADDR <<< "${XCURSOR_PATH}"
    for p in "${ADDR[@]}"; do
      if [[ "${p}" == "${HOME}"* ]]; then
        icon_dir="${p}"
        break
      fi
    done
  fi
  [ -z "${icon_dir}" ] && icon_dir="${HOME}/.local/share/icons"

  install -d "${pkgdir}/${icon_dir}"
  cp "${srcdir}/code.svg" "${pkgdir}/${icon_dir}/code.svg"

  install -d "${pkgdir}/${HOME}/.local/share/applications"
  cat <<EOF > "${pkgdir}/${HOME}/.local/share/applications/antigravity-ide.desktop"
[Desktop Entry]
Version=2.0
Name=Antigravity IDE
Comment=Google Antigravity IDE agentic development platform
Exec=${HOME}/.local/bin/antigravity-ide
Terminal=false
Type=Application
Icon=code
Categories=Development;IDE;IA;LLM;antigravity;gemini
StartupNotify=false
EOF
  chmod 644 "${pkgdir}/${HOME}/.local/share/applications/antigravity-ide.desktop"
  install -d "${pkgdir}/${HOME}/.gemini/antigravity-ide"
}

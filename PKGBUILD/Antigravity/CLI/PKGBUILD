# Maintainer: CheckTopLeft - Dont@reach.me
# Remnants: ~/.gemini/antigravity-cli (run post_remove or remove manually). Shell integration in user profiles must be cleaned manually.

pkgname=antigravity-cli
pkgver=1.0.10
_build=6349723456634880
pkgrel=1
pkgdesc="Google Antigravity CLI companion tool"
arch=('x86_64')
url="https://antigravity.google/"
license=('custom:Proprietary')
depends=('glibc')
options=('!strip' '!debug')
install=antigravity-cli.install
source=("cli_linux_x64.tar.gz::https://storage.googleapis.com/antigravity-public/antigravity-cli/${pkgver}-${_build}/linux-x64/cli_linux_x64.tar.gz"
        "agy.svg::https://raw.githubusercontent.com/Groupiely/Zbeul/main/PKGBUILD/Antigravity/CLI/agy.svg"
        "agyb.svg::https://raw.githubusercontent.com/Groupiely/Zbeul/main/PKGBUILD/Antigravity/CLI/agyb.svg"
        "agy.png::https://raw.githubusercontent.com/Groupiely/Zbeul/main/PKGBUILD/Antigravity/CLI/agy.png")
sha512sums=('SKIP'
            '492d410610afd404955c1d30e9d7319383a884fff253ec33cfb56fee8dc019010d0464e6d7b856bd3d21d8c165bae25cf0b28101418dc7ab687f6590fbfc16d1'
            '416f8d2b3ee579b2551fa68afd11a7c746e439282d1aea117764fcd1343f1444143b2a5362024b3bae85cf095c65df7c1d650932a84174a096fbbe0c7e21a273'
            '58dbb58da24c306d8c64bc93933bc3eba868b39425e5cf4e8284a777e943a0a7cf8d7fe1ad7ede9349fe0ab09334acd8bdebd79c4f209cbf62c171e067b415af')

package() {
  install -d "${pkgdir}/${HOME}/.local/bin"
  install -m755 "${srcdir}/antigravity" "${pkgdir}/${HOME}/.local/bin/agy"

  local icon_dir=""
  if [ -n "${XCURSOR_PATH}" ]; then
    IFS=':' read -ra ADDR <<< "${XCURSOR_PATH}"
    for p in "${ADDR[@]}"; do
      if [[ "${p}" == "${HOME}"* ]]; then
        icon_dir="${p}"
        break
      fi
    done
  fi
  [ -z "${icon_dir}" ] && icon_dir="${HOME}/.local/share/icons"

  install -d "${pkgdir}/${icon_dir}"
  cp "${srcdir}/agy.svg" "${pkgdir}/${icon_dir}/agy.svg"
  cp "${srcdir}/agyb.svg" "${pkgdir}/${icon_dir}/agyb.svg"
  cp "${srcdir}/agy.png" "${pkgdir}/${icon_dir}/agy.png"

  install -d "${pkgdir}/${HOME}/.local/share/applications"
  cat <<EOF > "${pkgdir}/${HOME}/.local/share/applications/antigravity-cli.desktop"
[Desktop Entry]
Version=1.0
Name=Antigravity CLI
Comment=Google Antigravity CLI companion tool
Exec=${HOME}/.local/bin/agy
Terminal=true
Type=Application
Icon=agy
Categories=Development;IA;LLM;antigravity;gemini
StartupNotify=false
EOF
  chmod 644 "${pkgdir}/${HOME}/.local/share/applications/antigravity-cli.desktop"
  install -d "${pkgdir}/${HOME}/.gemini/antigravity-cli"
}

# Maintainer: CheckTopLeft - Dont@reach.me
# Remnants: ~/.gemini/antigravity (run post_remove or remove manually).

pkgname=antigravity-orchestrator
pkgver=2.1.4
_build=6481382726303744
pkgrel=1
pkgdesc="Google Antigravity 2.0 multi-agent orchestration platform (Hub)"
arch=('x86_64')
url="https://antigravity.google/"
license=('custom:Proprietary')
depends=('alsa-lib' 'gtk3' 'nss' 'nspr' 'libxss' 'libxtst')
options=('!strip' '!debug')
install=antigravity-orchestrator.install
source=("Antigravity.tar.gz::https://storage.googleapis.com/antigravity-public/antigravity-hub/${pkgver}-${_build}/linux-x64/Antigravity.tar.gz"
        "agyagent.svg::https://raw.githubusercontent.com/Groupiely/Zbeul/main/PKGBUILD/Antigravity/Agent-Orchestrator/agyagent.svg")
sha512sums=('SKIP'
            'f821b24e72770e582d190d00c0f1ac63ef59a9e664eae8eb74da8a8f3272b5bbf9de96500d4802eca74e7912708edf28608ac498bce9b3d0e01173e7b8d831a7')

package() {
  install -d "${pkgdir}/${HOME}/.local/share/Antigravity"
  local ext_dir=$(find "${srcdir}" -maxdepth 1 -type d -name "Antigravity-*" | head -n 1)
  cp -a "${ext_dir}/"* "${pkgdir}/${HOME}/.local/share/Antigravity/"

  install -d "${pkgdir}/${HOME}/.local/bin"
  ln -sf "../share/Antigravity/antigravity" "${pkgdir}/${HOME}/.local/bin/antigravity"

  local icon_dir=""
  if [ -n "${XCURSOR_PATH}" ]; then
    IFS=':' read -ra ADDR <<< "${XCURSOR_PATH}"
    for p in "${ADDR[@]}"; do
      if [[ "${p}" == "${HOME}"* ]]; then
        icon_dir="${p}"
        break
      fi
    done
  fi
  [ -z "${icon_dir}" ] && icon_dir="${HOME}/.local/share/icons"

  install -d "${pkgdir}/${icon_dir}"
  cp "${srcdir}/agyagent.svg" "${pkgdir}/${icon_dir}/agyagent.svg"

  install -d "${pkgdir}/${HOME}/.local/share/applications"
  cat <<EOF > "${pkgdir}/${HOME}/.local/share/applications/antigravity-hub.desktop"
[Desktop Entry]
Version=2.0
Name=Antigravity Hub
Comment=Google Antigravity 2.0 multi-agent orchestration platform
Exec=${HOME}/.local/bin/antigravity
Terminal=false
Type=Application
Icon=agyagent
Categories=IA;LLM;agent;agy;antigravity;gemini
StartupNotify=false
MimeType=x-scheme-handler/antigravity;
EOF
  chmod 644 "${pkgdir}/${HOME}/.local/share/applications/antigravity-hub.desktop"
  install -d "${pkgdir}/${HOME}/.gemini/antigravity"
}
